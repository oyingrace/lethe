# Qwen Cloud (DashScope OpenAI-compatible mode) — required
QWEN_API_KEY=
MODEL_FAST=qwen-turbo
MODEL_REASONING=qwen-max
MODEL_EMBED=text-embedding-v3
MODEL_RERANK=gte-rerank

# Postgres (pgvector)
POSTGRES_USER=lethe
POSTGRES_PASSWORD=lethe
POSTGRES_DB=lethe
DATABASE_URL=postgresql://lethe:lethe@postgres:5432/lethe

# Redis (lifecycle scheduler / caching)
REDIS_URL=redis://redis:6379/0
